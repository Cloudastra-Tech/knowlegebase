# Copy this file to ".env" and paste your real key after the = sign.
# Get a key at: https://platform.openai.com/api-keys
# Keep .env SECRET. Never commit it to git.

OPENAI_API_KEY=sk-paste-your-key-here

# ---- Outline wiki (internal knowledge base) ----
# Your self-hosted Outline URL (no trailing slash).
OUTLINE_URL=https://app.cloudastra.co
# Create an API token in Outline: Settings -> API Tokens. Keep it SECRET.
OUTLINE_API_TOKEN=ol_api_paste-your-token-here
# If your Outline is behind Cloudflare Access (Zero Trust), create a Service
# Token (Zero Trust -> Access -> Service Auth) and paste both values here.
# Leave blank if your instance is NOT behind Cloudflare Access.
CF_ACCESS_CLIENT_ID=
CF_ACCESS_CLIENT_SECRET=
